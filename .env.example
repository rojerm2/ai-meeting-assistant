# Local Docker Compose configuration. Copy to .env only when you need to change a value.
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Comma-separated browser origins allowed to call the backend directly.
# Docker uses the frontend proxy, so this normally needs no change.
CORS_ALLOWED_ORIGINS=http://localhost:5173
